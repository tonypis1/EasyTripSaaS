{
  "name": "easytrip-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "dev": "next dev --webpack",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install",
    "screenshots:presentation": "node --max-old-space-size=8192 ./node_modules/@playwright/test/cli.js test -c playwright.presentation.config.ts",
    "screenshots:clerk-session": "node --max-old-space-size=8192 ./node_modules/@playwright/test/cli.js test -c playwright.clerk-session.config.ts",
    "presentation:pdf": "node scripts/export-presentation-pdf.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@clerk/nextjs": "^6",
    "@prisma/client": "6.19.0",
    "@types/leaflet": "^1.9.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "inngest": "^4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.475",
    "next": "16.1.7",
    "posthog-js": "^1.364.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "stripe": "^17",
    "zod": "^3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.11",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "prisma": "6.19.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
