{
  "name": "easytrip-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "dev": "next dev --webpack",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "test:unit": "vitest run --project unit",
    "test:unit:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep \"@smoke\"",
    "test:e2e:preview": "playwright test -c playwright.preview.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install",
    "screenshots:presentation": "node --max-old-space-size=8192 ./node_modules/@playwright/test/cli.js test -c playwright.presentation.config.ts",
    "screenshots:clerk-session": "node --max-old-space-size=8192 ./node_modules/@playwright/test/cli.js test -c playwright.clerk-session.config.ts",
    "presentation:pdf": "node scripts/export-presentation-pdf.cjs",
    "privacy:ropa": "node scripts/generate-processing-register.mjs",
    "check:env": "node scripts/check-env.mjs",
    "check:env:strict": "node scripts/check-env.mjs --strict",
    "check:env:production": "node scripts/check-env.mjs --production",
    "postdeploy:check": "node scripts/post-deploy-check.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@clerk/localizations": "^4.5.3",
    "@clerk/nextjs": "^6.39.3",
    "@prisma/client": "6.19.3",
    "@types/leaflet": "^1.9.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "inngest": "^4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.475",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "posthog-js": "^1.364.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "stripe": "^17",
    "zod": "^3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.11",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.3",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "@swc/helpers": "0.5.21",
    "dompurify": "3.4.1",
    "protobufjs": "7.5.5"
  }
}
