# Copia in `.env` e compila i valori. Non committare `.env`.
# Riferimenti: `src/config/unifiedConfig.ts`, `architecture-docs/13_CICD_SECRETS_AND_DNS.md`

# --- Core (obbligatori per avvio app, validati da Zod) ---
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Neon DB:
DATABASE_URL=postgresql://neondb_owner...

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Produzione (Account Portal su sottodominio): imposta l’origine così i bottoni Accedi/Registrati
# usano un link diretto https://accounts.../sign-in|sign-up?redirect_url=... anche se clerk-js è lento o bloccato.
# Vedi Dashboard Clerk → Paths (es. https://accounts.tuodominio.com).
# NEXT_PUBLIC_CLERK_ACCOUNT_PORTAL_ORIGIN=https://accounts.easytripsaas.com
# In alternativa URL completi:
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://accounts.easytripsaas.com/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://accounts.easytripsaas.com/sign-up
# Webhook user.created (benvenuto). Senza: /api/webhooks/clerk → 503
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Opzionale: abbonamento SaaS (Price ID ricorrente, formato price_...)
# Crealo in Stripe Dashboard → Products → "+ New product" → Recurring, €6,99/mese.
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# Opzionale: ID del Promotion Code (formato promo_..., NON il codice human-readable)
# Sconto "Nuovo viaggio - 20%" applicato automaticamente se l'utente ha un trip
# pagato finito negli ultimi 7 giorni. Se non impostato, lo sconto è disabilitato.
# Crealo in Stripe Dashboard → Products → Coupons → poi Promotion Codes.
# STRIPE_PROMO_CODE_NEW_TRIP_ID=promo_...

# Prezzi in centesimi (default nel codice se omessi)
# STRIPE_PRICE_SOLO_COUPLE_CENTS=399
# STRIPE_PRICE_GROUP_CENTS=699
# STRIPE_PRICE_REGEN_CENTS=199
# STRIPE_PRICE_REACTIVATE_CENTS=290
# STRIPE_PRICE_LOCALPASS_CENTS=399

ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Retention (default nel codice) ---
# RETENTION_INACTIVE_TRIP_VERSION_DAYS=365
# RETENTION_SOFT_DELETED_TRIP_DAYS=90

# --- Email transazionale (opzionale in schema; consigliato in prod) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM="EasyTrip <noreply@tuodominio.it>"

# --- Inngest Cloud (Vercel produzione / preview) ---
# Dashboard → sincronizza con https://TUO_DOMINIO/api/inngest
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# --- Rate limit (opzionale) ---
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# --- PostHog (client) ---
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Crisp (client) ---
# NEXT_PUBLIC_CRISP_WEBSITE_ID=...

# --- Affiliazioni (tutte opzionali, pubbliche) ---
# NEXT_PUBLIC_BOOKING_AID=
# NEXT_PUBLIC_GYG_PARTNER_ID=
# NEXT_PUBLIC_THEFORK_PARTNER_ID=
# NEXT_PUBLIC_VIATOR_PID=
# NEXT_PUBLIC_AMAZON_TAG=

# --- Solo sviluppo ---
# NEXT_PUBLIC_DEV_PREVIEW_UNLOCKED=true

# --- Playwright / CI ---
# E2E_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_SKIP_WEBSERVER=
